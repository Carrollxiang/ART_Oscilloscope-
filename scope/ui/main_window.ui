  <!-- ─── Central Widget ─── -->
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="centralLayout">
    <!-- 上: 波形区 (占大部分空间) -->
    <item stretch="2">
     <widget class="QWidget" name="waveformContainer" native="true"/>
    </item>

    <!-- 下: 迷你图(左) + 配置面板(右) -->
    <item stretch="1">
     <layout class="QHBoxLayout" name="bottomArea">
      <item stretch="1">
       <widget class="QWidget" name="miniChartContainer" native="true"/>
      </item>
      <item stretch="3">
       <widget class="QTabWidget" name="bottomTabs">

        <!-- Tab 0: 通道 -->
        <widget class="QWidget" name="tabChannels">
         <attribute name="title"><string>通道</string></attribute>
         <layout class="QVBoxLayout" name="channelsLayout"/>
        </widget>

        <!-- Tab 1: 设备设置 (替代原触发) -->
        <widget class="QWidget" name="tabDevice">
         <attribute name="title"><string>设备设置</string></attribute>
         <layout class="QVBoxLayout" name="deviceLayout"/>
        </widget>

        <!-- Tab 2: 测量 -->
        <widget class="QWidget" name="tabMeasurements">
         <attribute name="title"><string>测量</string></attribute>
         <layout class="QVBoxLayout" name="measurementsLayout">
          <item>
           <widget class="QTableWidget" name="measurementTable">
            <column>
             <property name="text"><string>测量项</string></property>
            </column>
            <column>
             <property name="text"><string>值</string></property>
            </column>
           </widget>
          </item>
         </layout>
        </widget>

        <!-- Tab 3: 反馈 (空容器, 由 FeedbackPanel 填充) -->
        <widget class="QWidget" name="tabFeedback">
         <attribute name="title"><string>反馈</string></attribute>
         <layout class="QVBoxLayout" name="feedbackLayout"/>
        </widget>
       </widget>
      </item>
     </layout>
    </item>

    <!-- 底部测量条 -->
    <item>
     <widget class="QFrame" name="measurementBar">
      <property name="maximumSize">
       <size><width>16777215</width><height>32</height></size>
      </property>
      <layout class="QHBoxLayout" name="measurementBarLayout">
       <item>
